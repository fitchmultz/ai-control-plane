{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "AI Control Plane Helm Values",
  "type": "object",
  "required": ["profile", "demo", "litellm", "secrets", "postgres"],
  "properties": {
    "profile": {
      "type": "string",
      "enum": ["production", "demo"]
    },
    "demo": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "litellm": {
      "type": "object",
      "required": ["replicaCount", "service", "mode"],
      "properties": {
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort"]
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "nodePort": {
              "type": ["integer", "null"],
              "minimum": 30000,
              "maximum": 32767
            }
          }
        },
        "mode": {
          "type": "string",
          "enum": ["online", "offline"]
        },
        "publicUrl": {
          "type": "string",
          "pattern": "^$|^https://.+"
        },
        "podSecurityContext": {
          "type": "object",
          "properties": {
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer", "minimum": 1 },
            "runAsGroup": { "type": "integer", "minimum": 1 },
            "fsGroup": { "type": "integer", "minimum": 1 }
          }
        },
        "securityContext": {
          "type": "object",
          "properties": {
            "allowPrivilegeEscalation": { "type": "boolean" },
            "runAsNonRoot": { "type": "boolean" },
            "runAsUser": { "type": "integer", "minimum": 1 },
            "runAsGroup": { "type": "integer", "minimum": 1 },
            "readOnlyRootFilesystem": { "type": "boolean" },
            "capabilities": {
              "type": "object",
              "properties": {
                "drop": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "secrets": {
      "type": "object",
      "required": ["create", "existingSecret"],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "existingSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "masterKeyKey": { "type": "string" },
            "saltKeyKey": { "type": "string" },
            "databaseUrlKey": { "type": "string" }
          }
        },
        "litellm": {
          "type": "object",
          "properties": {
            "masterKey": { "type": "string" },
            "saltKey": { "type": "string" }
          }
        },
        "externalDatabaseUrl": {
          "type": "string",
          "pattern": "^$|^postgresql://.+"
        }
      },
      "additionalProperties": true
    },
    "postgres": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "auth": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" },
            "database": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "existingSecret": { "type": "string" },
        "existingSecretKey": { "type": "string" }
      },
      "additionalProperties": true
    },
    "mockUpstream": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["host", "paths"],
            "properties": {
              "host": { "type": "string", "minLength": 1 },
              "paths": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["secretName", "hosts"],
            "properties": {
              "secretName": { "type": "string", "minLength": 1 },
              "hosts": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "automountServiceAccountToken": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": true
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingress": { "type": "array" }
      },
      "additionalProperties": true
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "tlsConfig": {
              "type": "object",
              "properties": {
                "insecureSkipVerify": { "type": "boolean" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": { "const": "demo" }
        }
      },
      "then": {
        "properties": {
          "demo": {
            "properties": {
              "enabled": { "const": true }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "demo": {
            "properties": {
              "enabled": { "const": false }
            }
          }
        }
      },
      "then": {
        "properties": {
          "profile": { "const": "production" },
          "secrets": {
            "properties": {
              "create": { "const": false },
              "existingSecret": {
                "required": ["name"],
                "properties": {
                  "name": { "minLength": 1 }
                }
              }
            }
          },
          "postgres": {
            "properties": {
              "enabled": { "const": false }
            }
          },
          "networkPolicy": {
            "properties": {
              "enabled": { "const": true }
            }
          },
          "podDisruptionBudget": {
            "properties": {
              "enabled": { "const": true }
            }
          },
          "litellm": {
            "properties": {
              "mode": { "const": "online" },
              "replicaCount": { "minimum": 2 },
              "service": {
                "properties": {
                  "type": { "const": "ClusterIP" }
                }
              },
              "podSecurityContext": {
                "properties": {
                  "runAsNonRoot": { "const": true },
                  "runAsUser": { "minimum": 1 },
                  "runAsGroup": { "minimum": 1 },
                  "fsGroup": { "minimum": 1 }
                }
              },
              "securityContext": {
                "properties": {
                  "allowPrivilegeEscalation": { "const": false },
                  "runAsNonRoot": { "const": true }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ingress": {
            "properties": {
              "enabled": { "const": true }
            }
          }
        }
      },
      "then": {
        "properties": {
          "ingress": {
            "properties": {
              "className": { "minLength": 1 },
              "hosts": { "minItems": 1 }
            }
          }
        }
      }
    }
  ]
}
