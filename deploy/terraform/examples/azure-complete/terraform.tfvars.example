#   enable_auto_scaling  = true
#   only_critical_addons = true
#   labels               = {}
#   taints               = ["CriticalAddonsOnly=true:NoSchedule"]
# }

# node_pools = {
#   general = {
#     vm_size             = "Standard_D4s_v3"
#     node_count          = 3
#     min_count           = 2
#     max_count           = 10
#     os_disk_size_gb     = 128
#     enable_auto_scaling = true
#     labels = {
#       workload-type = "general"
#     }
#     taints = []
#   }
# }

# postgresql_sku_name = "GP_Standard_D4s_v3"
# postgresql_storage_mb = 65536
# postgresql_geo_redundant_backup_enabled = true
# postgresql_high_availability_enabled = true
# postgresql_backup_retention_days = 35

# litellm_replica_count = 2
# enable_autoscaling = true
# ingress_enabled = true
# ingress_host = "ai-control-plane.yourcompany.com"
