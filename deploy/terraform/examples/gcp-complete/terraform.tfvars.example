# -----------------------------------------------------------------------------
# GCP Complete Example - Terraform Variables Example
# -----------------------------------------------------------------------------
# Copy this file to terraform.tfvars and update with your values:
#   cp terraform.tfvars.example terraform.tfvars
#
# Then run:
#   terraform init
#   terraform plan
#   terraform apply
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Required Variables
# -----------------------------------------------------------------------------

# GCP project ID (required)
project_id = "your-gcp-project-id"

# -----------------------------------------------------------------------------
# General Configuration (Optional - reasonable defaults provided)
# -----------------------------------------------------------------------------

# GCP region for all resources
# region = "us-central1"

# Environment tag (production is the supported primary deployment baseline)
# environment = "production"

# Resource name prefix
# name_prefix = "ai-cp"

# -----------------------------------------------------------------------------
# VPC Configuration (Optional)
# -----------------------------------------------------------------------------

# VPC CIDR block
# vpc_cidr = "10.0.0.0/16"

# GKE subnet CIDR
# gke_subnet_cidr = "10.0.0.0/20"

# Pods IP range (secondary)
# pods_ip_range = { name = "pods", cidr = "10.4.0.0/14" }

# Services IP range (secondary)
# services_ip_range = { name = "services", cidr = "10.0.32.0/20" }

# -----------------------------------------------------------------------------
# GKE Configuration (Optional)
# -----------------------------------------------------------------------------

# Kubernetes version
# kubernetes_version = "1.29"

# Release channel (UNSPECIFIED, RAPID, REGULAR, STABLE)
# release_channel = "REGULAR"

# Enable private nodes
# enable_private_nodes = true

# Master authorized networks (required)
# master_authorized_networks = [
#   {
#     cidr_block   = "YOUR_OFFICE_IP/32"
#     display_name = "Office Network"
#   }
# ]

# Custom node pools (if not specified, defaults based on environment)
# node_pools = {
#   general = {
#     machine_type       = "e2-standard-2"
#     initial_node_count = 2
#     min_count          = 2
#     max_count          = 5
#     disk_size_gb       = 100
#     spot               = false
#     labels = {
#       workload = "general"
#     }
#   }
#   spot = {
#     machine_type       = "e2-medium"
#     initial_node_count = 0
#     min_count          = 0
#     max_count          = 3
#     disk_size_gb       = 100
#     spot               = true
#     labels = {
#       workload = "batch"
#     }
#   }
# }

# -----------------------------------------------------------------------------
# Cloud SQL Configuration (Optional)
# -----------------------------------------------------------------------------

# Cloud SQL tier (auto-set per environment if not specified)
# dev: db-f1-micro, staging: db-g1-small, production: db-n1-standard-2
# cloudsql_tier = "db-f1-micro"

# Cloud SQL availability (auto-set per environment if not specified)
# dev/staging: ZONAL, production: REGIONAL
# cloudsql_availability_type = "ZONAL"

# Cloud SQL disk size
# cloudsql_disk_size = 20

# Enable automatic disk resizing
# cloudsql_disk_autoresize = true

# Backup retention count
# cloudsql_backup_retention = 7

# Database name
# database_name = "litellm"

# Database username
# database_user = "litellm"

# -----------------------------------------------------------------------------
# Helm Release Configuration (Optional)
# -----------------------------------------------------------------------------

# Helm release name
# helm_release_name = "acp"

# Kubernetes namespace
# namespace = "acp"

# LiteLLM master key (required)
# litellm_master_key = "replace-with-32-character-minimum-master-key"

# LiteLLM salt key (required)
# litellm_salt_key = "replace-with-32-character-minimum-salt-key"

# Enable ingress only after DNS and cert-manager are ready
# ingress_enabled = false

# Ingress hostname (required if ingress_enabled = true)
# ingress_host = "ai-control-plane.example.com"

# Ingress class name
# ingress_class_name = "nginx"

# TLS secret and cert-manager issuer (required if ingress_enabled = true)
# ingress_tls_secret_name = "ai-control-plane-tls"
# ingress_cluster_issuer = "letsencrypt-prod"

# -----------------------------------------------------------------------------
# Example Configurations
# -----------------------------------------------------------------------------

# Production configuration (high availability)
# ---------------------------------------------
# environment = "production"
# region = "us-central1"
# cloudsql_tier = "db-n1-standard-2"
# cloudsql_availability_type = "REGIONAL"
# ingress_enabled = true
# ingress_host = "ai-control-plane.yourdomain.com"
# master_authorized_networks = [
#   {
#     cidr_block   = "YOUR_OFFICE_IP/32"
#     display_name = "Office Network"
#   }
# ]
