# ============================================================================
# LiteLLM Environment Configuration Template
# ============================================================================
# Purpose: Template for demo/.env - DO NOT put real secrets in this file.
# Usage:   Copy this file to .env and replace placeholder values with actual
#          configuration for your environment.
#
# Setup commands:
#   cp .env.example .env
#   # Edit .env with your values
#
# Security:
#   - This file should ALWAYS be safe to commit (no real secrets)
#   - The actual .env file is gitignored and contains real credentials
#   - See docs/deployment/SINGLE_TENANT_PRODUCTION_CONTRACT.md for production
#     deployment requirements
#
# Production Secrets Contract (RQ-0172):
#   For production deployments, secrets should be managed via the canonical path:
#     /etc/ai-control-plane/secrets.env
#   Lock that file down before validation:
#     install -m 600 /dev/null /etc/ai-control-plane/secrets.env
#   This file provides the demo/local development template.
#   See docs/deployment/PRODUCTION_HANDOFF_RUNBOOK.md for rotation workflow.
#
# Validation:
#   Validate demo/local configuration:
#     make validate-config
#
#   Validate production configuration:
#     make validate-config-production SECRETS_ENV_FILE=/etc/ai-control-plane/secrets.env
# ============================================================================

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# LiteLLM Master Key
# Purpose: Admin authentication key used to generate per-tool virtual keys
# Required: Yes - LiteLLM will not start without this
# Format: ~64-character string (48 bytes base64-encoded, '=' padding removed)
# Generate: openssl rand -base64 48 | tr -d '\n='
# Validation: Must be >= 32 chars, no whitespace/newlines, not a placeholder
# SECURITY: This key controls admin access to the gateway. Keep it secret.
# PLACEHOLDER: The value below is a placeholder and will be rejected by scripts.
#              Replace it with a generated key before running demos.
LITELLM_MASTER_KEY=sk-litellm-master-change-me

# LiteLLM Salt Key
# Purpose: Persistent salt for encrypting virtual keys and sensitive data
# Required: Yes - Required for key encryption features
# Format: ~64-character string (48 bytes base64-encoded, '=' padding removed)
# Generate: openssl rand -base64 48 | tr -d '\n='
# SECURITY: Treat as persistent secret. Regenerating invalidates encrypted data.
# PLACEHOLDER: The value below is a placeholder - replace with a generated key.
LITELLM_SALT_KEY=sk-litellm-salt-change-me

# ============================================================================
# DATABASE MODE CONFIGURATION
# ============================================================================

# Database Deployment Mode
# Purpose: Select embedded (local compose) or external (split-host) PostgreSQL
# Required: No - Defaults to 'embedded' for backward compatibility
# Values:
#   - embedded: Use local PostgreSQL container (default, suitable for single-host)
#   - external: Use external PostgreSQL host (split-host deployment)
# Note: In external mode, POSTGRES_* variables are not required and postgres
#       service is not started. DATABASE_URL must point to external DB host.
# See: docs/deployment/SINGLE_TENANT_PRODUCTION_CONTRACT.md
ACP_DATABASE_MODE=embedded

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL Database User
# Purpose: Database user for PostgreSQL authentication
# Required: Yes - Must match postgres service configuration
# Default: litellm (demo default, change for production)
# SECURITY: Database credentials should be strong in production
POSTGRES_USER=litellm

# PostgreSQL Database Password
# Purpose: Database password for PostgreSQL authentication
# Required: Yes - Must match postgres service configuration
# Production: Must be >= 16 characters, cannot be 'litellm' (demo default)
# Generate: openssl rand -base64 24 | tr -d '\n='
# SECURITY: Use strong password in production.
POSTGRES_PASSWORD=litellm

# PostgreSQL Database Name
# Purpose: Database name to create/use
# Required: Yes
# Default: litellm
POSTGRES_DB=litellm

# PostgreSQL Connection String
# Purpose: Database connection for virtual keys, budgets, and usage logs
# Required: Yes - Must match docker-compose.yml postgres service config
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Note: Docker Compose reads this at runtime. Values must match POSTGRES_* above.
# SECURITY: Contains database credentials. The .env file is gitignored.
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# External Database Configuration (ACP_DATABASE_MODE=external)
# Purpose: Connection to external PostgreSQL host in split-host deployments
# Required: Only when ACP_DATABASE_MODE=external
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# Security: Use sslmode=require for production external connections
# Example: postgresql://litellm:securepassword@db.example.com:5432/litellm?sslmode=require
# EXTERNAL_DATABASE_URL=postgresql://litellm:securepassword@db.example.com:5432/litellm?sslmode=require

# ============================================================================
# NETWORK CONFIGURATION
# ============================================================================

# LiteLLM Publish Host
# Purpose: Interface to bind LiteLLM gateway (127.0.0.1 = localhost only)
# Required: No - Defaults to 127.0.0.1 (localhost only, safest)
# Values:
#   - 127.0.0.1 (default): Bind to localhost only - suitable for local dev
#   - 0.0.0.0: Demo-only troubleshooting path
# SECURITY: Production validation requires LiteLLM to stay localhost-bound and
#           be exposed only through the TLS Caddy ingress.
# See: docs/deployment/SINGLE_TENANT_PRODUCTION_CONTRACT.md
LITELLM_PUBLISH_HOST=127.0.0.1

# ============================================================================
# OPTIONAL PROVIDER KEYS
# ============================================================================
# Purpose: API keys for LLM providers (for API-key mode demos)
# Required: No - The gateway can run without these for testing
# Note: Only add keys for local testing. Never commit real keys.
#
# Usage: Uncomment and set keys for providers you want to use in API-key mode.
#        See demo/config/litellm.yaml for configured model aliases.
#
# Provider documentation:
#   - OpenAI: https://platform.openai.com/api-keys
#   - Anthropic: https://console.anthropic.com/settings/keys
#   - Google Gemini: https://makersuite.google.com/app/apikey

# OpenAI API Key (optional)
# Purpose: Access to OpenAI models (GPT-4o, etc.) in API-key mode
# Format: sk-...
# SECURITY: Never commit real keys. Rotate if exposed.
OPENAI_API_KEY=

# Anthropic API Key (optional)
# Purpose: Access to Anthropic Claude models in API-key mode
# Format: sk-ant-...
# SECURITY: Never commit real keys. Rotate if exposed.
ANTHROPIC_API_KEY=

# Google Gemini API Key (optional)
# Purpose: Access to Google Gemini models in API-key mode
# Format: AIza...
# SECURITY: Never commit real keys. Rotate if exposed.
GEMINI_API_KEY=

# ============================================================================
# OPTIONAL BUDGET AND RATE LIMIT CONFIGURATION
# ============================================================================
# Purpose: Override default budget and rate limit settings from litellm.yaml
# Required: No - Uses litellm.yaml defaults if not set
# Note: These are optional overrides. Most configuration is in litellm.yaml.
# Documentation: See docs/BUDGETS_AND_RATE_LIMITS.md for details.

# Global Proxy Budget Limit (optional)
# Purpose: Maximum spend for the entire gateway before blocking all requests
# Format: Float value in USD (e.g., 100.0, 50.00)
# Default: 100.0 (if not set, uses litellm.yaml default)
#LITELLM_MAX_BUDGET=100.0

# Budget Duration (optional)
# Purpose: Time period before budget resets
# Format: Duration string (e.g., 30d, 7d, 1h, 30s)
# Default: 30d (monthly reset)
#LITELLM_BUDGET_DURATION=30d

# Maximum Parallel Requests (optional)
# Purpose: Maximum concurrent requests across all keys
# Format: Integer value
# Default: 100
#LITELLM_MAX_PARALLEL=100

# Internal User Budget (optional)
# Purpose: Default budget limit for internal users
# Format: Float value in USD
# Default: 10.0
#LITELLM_MAX_INTERNAL_USER_BUDGET=10.0

# Internal User Budget Duration (optional)
# Purpose: Time period before internal user budgets reset
# Format: Duration string (e.g., 7d, 1d)
# Default: 7d
#LITELLM_INTERNAL_USER_BUDGET_DURATION=7d

# ============================================================================
# OPTIONAL TLS/HTTPS CONFIGURATION
# ============================================================================
# Purpose: Enable reverse proxy with TLS support for secure HTTPS connections
# Required: No - TLS is optional for local demo environments
# Required: Yes - When LITELLM_PUBLISH_HOST=0.0.0.0 in production
# Usage:    Uncomment and set these variables when using docker-compose.tls.yml
# See:      docs/deployment/TLS_SETUP.md for complete documentation
# Contract: docs/deployment/SINGLE_TENANT_PRODUCTION_CONTRACT.md

# Caddy Publish Host
# Purpose: Interface to bind Caddy reverse proxy ports (80/443)
# Required: No - Defaults to 127.0.0.1 (localhost only, safest)
# Values:
#   - 127.0.0.1 (default): Bind to localhost only - suitable for local dev
#   - 0.0.0.0: Bind to all interfaces - required for external TLS access
# SECURITY: Production validation requires external exposure to use:
#   CADDYFILE_PATH=./config/caddy/Caddyfile.prod
#   CADDY_ACME_CA=letsencrypt
#   CADDY_DOMAIN / CADDY_EMAIL
CADDY_PUBLISH_HOST=127.0.0.1

# Caddyfile Path
# Purpose: Path to Caddyfile configuration (relative to demo/ or absolute)
# Required: No - Defaults to ./config/caddy/Caddyfile.dev
# Values:
#   - ./config/caddy/Caddyfile.dev (self-signed, local development)
#   - ./config/caddy/Caddyfile.prod (Let's Encrypt, production)
# SECURITY: Exposed production ingress must use ./config/caddy/Caddyfile.prod
CADDYFILE_PATH=./config/caddy/Caddyfile.dev

# TLS Certificate Mode
# Purpose: Choose between self-signed or Let's Encrypt certificates
# Values:  internal (self-signed, for local/dev), letsencrypt (production)
# Default: internal
# Note:    'internal' uses Caddy's built-in CA for self-signed certificates
#          'letsencrypt' requires a valid domain name and public HTTP access
CADDY_ACME_CA=internal

# Caddy Domain (for Let's Encrypt)
# Purpose: Domain name for automatic certificate provisioning
# Required: Only when using Let's Encrypt mode (CADDY_ACME_CA=letsencrypt)
# Example: gateway.example.com
# Note:    Must be a publicly resolvable domain name with DNS configured
#CADDY_DOMAIN=

# Caddy Email (for Let's Encrypt)
# Purpose: Email address for Let's Encrypt certificate expiration notices
# Required: Only when using Let's Encrypt mode (CADDY_ACME_CA=letsencrypt)
# Example: admin@example.com
#CADDY_EMAIL=

# LiteLLM Public URL (for TLS mode)
# Purpose: The public URL that clients will use to access the gateway
# Required: Only when using TLS mode
# Values:  https://localhost (local), https://your-domain.com (production)
# Example: https://gateway.example.com
# Note:    Must start with https:// when TLS is enabled
LITELLM_PUBLIC_URL=https://localhost

# ============================================================================
# OPTIONAL OPENTELEMETRY (OTEL) COLLECTOR CONFIGURATION
# ============================================================================
# Purpose: Enable OTEL collector for direct subscription/bypass telemetry
#          and optional client-side correlation telemetry
# Required: No - OTEL is optional for local demo
# Required: Yes - For production deployments with telemetry requirements
# Usage:    Uncomment these variables when using docker-compose with OTEL
# See:      docs/observability/OTEL_SETUP.md for complete documentation

# Config Profile Selection
# Purpose: Select OTEL collector configuration profile
# Values:  config.yaml (demo, default), config.production.yaml (production)
# Note:    Production profile requires OTEL_EXPORTER_OTLP_ENDPOINT
#OTEL_COLLECTOR_CONFIG_FILE=config.yaml

# OTEL Collector Endpoint (for Codex/other clients - local demo mode)
# Purpose: OTLP endpoint where clients send telemetry
# Format:  host:port
# Default: 127.0.0.1:4317 (gRPC), 127.0.0.1:4318 (HTTP)
# Note:    Remote production ingestion must use the HTTPS OTLP path described below.
#OTEL_EXPORTER_OTLP_ENDPOINT=127.0.0.1:4317

# OTEL Remote Exporter Endpoint (production mode)
# Purpose: Remote OTLP endpoint for production telemetry export
# Required: Yes - When using production profile
# Format:  https://endpoint (e.g., https://api.honeycomb.io, https://trace.agent.datadoghq.com)
# Examples:
#   Honeycomb: https://api.honeycomb.io
#   Datadog:   https://trace.agent.datadoghq.com
#   Grafana:   https://tempo-prod-XX.grafana.net
#OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-backend.example.com

# OTEL Authentication Header (production mode)
# Purpose: Auth header for remote OTLP endpoint
# Format:  "Api-Key your-key" or "Authorization Bearer token"
# SECURITY: Never commit real keys. Use secrets management in production.
#OTEL_EXPORTER_OTLP_AUTH_HEADER="Api-Key your-api-key"

# OTEL HTTPS ingress shared secret (required for remote client -> collector ingress)
# Purpose: Protect the Caddy `/otel/*` HTTPS ingress route used for remote OTLP/HTTP clients
# Format:  Bearer token value without the `Bearer ` prefix
# Example client header: Authorization: Bearer <token>
# SECURITY: Production validation requires this token for remote OTEL ingress.
#OTEL_INGEST_AUTH_TOKEN=replace-with-long-random-token

# Raw OTEL ports (4317/4318/13133) are fixed to 127.0.0.1 in docker-compose.yml.
# There is no production override. Remote OTEL clients must use:
#   https://<gateway-domain>/otel
# with:
#   Authorization: Bearer ${OTEL_INGEST_AUTH_TOKEN}

# OTEL Protocol
# Purpose: Protocol to use for OTEL export
# Values:  http/protobuf (production collector export)
# Note:    Production collector config uses OTLP/HTTP exporter
#OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# OTEL Resource Attributes
# Purpose: Tag telemetry with deployment context
# Required: Yes - When using production profile (must not be 'demo')
# Examples:
#   OTEL_RESOURCE_ENVIRONMENT=production
#   OTEL_RESOURCE_DEPLOYMENT=us-east-1
#OTEL_RESOURCE_ENVIRONMENT=demo
#OTEL_RESOURCE_DEPLOYMENT=local

# OTEL Sampling Configuration
# Purpose: Control telemetry volume and costs
# Format:  0-100 (percentage)
# Default: 10 (10% sampling)
# Note:    Adjust based on volume: high=1%, medium=10%, low=50-100%
#OTEL_TRACES_SAMPLING_PERCENT=10

# OTEL Memory Limit
# Purpose: Prevent OOM conditions in collector
# Format:  Integer (MiB)
# Default: 256
#OTEL_MEMORY_LIMIT_MIB=256

# OTEL Batch Size
# Purpose: Number of items per batch
# Format:  Integer
# Default: 512
#OTEL_BATCH_SIZE=512

# OTEL Service Name (for telemetry attribution)
# Purpose: Service name in OTEL telemetry data
# Default: codex-cli
# Note:    Helps identify telemetry source in SIEM/dashboards
#OTEL_SERVICE_NAME=codex-cli

# ============================================================================
# DEPLOYMENT PROFILE
# ============================================================================
# Purpose: Specify the deployment profile for validation purposes
# Required: No - Defaults to 'production' in validation scripts
# Values:   demo, production
# Note:     Set this to communicate intent to validation tools
#ACP_DEPLOYMENT_PROFILE=production

# ============================================================================
# LIBRECHAT (STANDARD MANAGED WEB UI)
# ============================================================================
# Purpose: Configure managed LibreChat web UI (governed browser chat)
# Required: Yes for default `make up` workflow
# Usage:    make up (default), make librechat-up (explicit service start)
# Docs:     docs/tooling/LIBRECHAT.md
#
# Security Notes:
#   - LIBRECHAT_CREDS_KEY and LIBRECHAT_CREDS_IV are REQUIRED for encryption
#   - LIBRECHAT_LITELLM_API_KEY should be a virtual key from `make key-gen`
#   - JWT_SECRET and JWT_REFRESH_SECRET are REQUIRED for local auth boot
#   - `make up` and `make librechat-up` validate these fields before startup
#
# Generate required encryption keys:
#   LIBRECHAT_CREDS_KEY=$(openssl rand -hex 32)
#   LIBRECHAT_CREDS_IV=$(openssl rand -hex 16)
#   LIBRECHAT_MEILI_MASTER_KEY=$(openssl rand -base64 32)
#   JWT_SECRET=$(openssl rand -hex 32)
#   JWT_REFRESH_SECRET=$(openssl rand -hex 32)
# ============================================================================

# LibreChat Service Configuration
LIBRECHAT_PUBLISH_HOST=127.0.0.1
LIBRECHAT_PORT=3080
LIBRECHAT_MONGO_URI=mongodb://librechat-mongodb:27017/LibreChat

# LibreChat Encryption Keys (REQUIRED - generate with openssl)
LIBRECHAT_CREDS_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
LIBRECHAT_CREDS_IV=0123456789abcdef0123456789abcdef
LIBRECHAT_MEILI_MASTER_KEY=demo-only-meili-master-key-rotate-me

# LiteLLM API Key for LibreChat (use virtual key from `make key-gen`)
# LIBRECHAT_LITELLM_API_KEY=sk-...

# LibreChat Local Auth JWT Secrets (REQUIRED for app startup)
JWT_SECRET=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
JWT_REFRESH_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
