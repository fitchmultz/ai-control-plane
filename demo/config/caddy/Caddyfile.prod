# Caddyfile for production deployment
# Uses Let's Encrypt for automatic TLS certificates
#
# Purpose: Provide production-grade HTTPS with automatic certificate management
# Security: Valid certificates from Let's Encrypt CA
# Usage: Set CADDY_DOMAIN and CADDY_EMAIL env vars, then use with
#        docker-compose.tls.yml (CADDYFILE_PATH=./config/caddy/Caddyfile.prod)
#
# Configuration:
#   This file uses environment variables for all site-specific values:
#   - CADDY_DOMAIN: Your domain name (e.g., gateway.example.com)
#   - CADDY_EMAIL: Email for Let's Encrypt notifications
#
#   These are passed via docker-compose.tls.yml environment section.
#
# See: docs/deployment/TLS_SETUP.md
# See: docs/deployment/SINGLE_TENANT_PRODUCTION_CONTRACT.md

{
    # Email for Let's Encrypt certificate notifications
    email {$CADDY_EMAIL}

    # Use Let's Encrypt production CA (remove for testing with staging)
    # To use staging (for testing): uncomment the line below
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# HTTPS endpoint with automatic Let's Encrypt certificates
# The domain is set via CADDY_DOMAIN environment variable
{$CADDY_DOMAIN} {
    # Request body size limit (10MB) - prevents DoS from oversized payloads
    request_body {
        max_size 10MB
    }

    # Content-Type validation - only allow JSON for API endpoints
    @nonJsonAPI {
        path /v1/*
        method POST PUT PATCH
        not header Content-Type application/json
        not header Content-Type application/json;*
    }
    respond @nonJsonAPI "Content-Type must be application/json" 415

    # Handle request body too large errors
    handle_errors 413 {
        respond "Request body too large. Maximum size is 10MB." 413
    }

    # Remote OTEL ingestion is HTTPS-only and requires an explicit shared secret.
    handle_path /otel/* {
        @authorized header Authorization "Bearer {$OTEL_INGEST_AUTH_TOKEN}"
        reverse_proxy @authorized otel-collector:4318
        respond "OTEL ingest authorization required" 401
    }

    # Reverse proxy to LiteLLM with retry logic for resilience
    reverse_proxy litellm:4000 {
        # Retry on connection failures (up to 3 attempts)
        lb_retries 3
    }

    # Log configuration (IMPORTANT: do NOT log headers - OAuth token safety)
    log {
        output file /var/log/caddy/access.log
        format json
        # NO log_headers directive - headers must not be logged
    }

    # Security headers (production-grade)
    header {
        # Enable HSTS with preload (production standard)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"
        # Prevent clickjacking
        X-Frame-Options "DENY"
        # XSS protection
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Content Security Policy (adjust based on your needs)
        # Content-Security-Policy "default-src 'self'"
        # Remove server identifier
        -Server
    }

    # Health check endpoint (bypasses proxy for direct health monitoring)
    handle /health {
        respond "Caddy Reverse Proxy - Healthy" 200
    }
}

# Automatic HTTP to HTTPS redirect
http://{$CADDY_DOMAIN} {
    redir https://{$CADDY_DOMAIN}{uri} permanent
}

# Optional: Support www subdomain (uncomment if needed)
# www.{$CADDY_DOMAIN} {
#     redir https://{$CADDY_DOMAIN}{uri} permanent
# }
