{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-control-plane.local/contracts/config/demo_presets.schema.json",
  "type": "object",
  "required": ["presets", "settings"],
  "properties": {
    "presets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "name",
          "description",
          "timeout_minutes",
          "scenarios",
          "stop_on_fail",
          "intro_message"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "timeout_minutes": { "type": "integer", "minimum": 1 },
          "scenarios": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "integer", "minimum": 1 }
          },
          "stop_on_fail": { "type": "boolean" },
          "intro_message": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "settings": {
      "type": "object",
      "required": ["default_timeout_minutes", "scenario_delay_seconds", "colors_enabled"],
      "properties": {
        "default_timeout_minutes": { "type": "integer", "minimum": 1 },
        "scenario_delay_seconds": { "type": "integer", "minimum": 0 },
        "colors_enabled": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
